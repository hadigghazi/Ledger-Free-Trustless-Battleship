# URL of YOUR local prover agent (the Rust zk-battleship-agent binary).
# It holds your secret board and does all proving/verifying.
# Use 127.0.0.1 (not `localhost`): browsers may try IPv6 ::1 first, which
# fails when the agent runs inside WSL2 (IPv4-only loopback forwarding).
NEXT_PUBLIC_PROVER_URL=http://127.0.0.1:8787

# URL of the cloud relay (the zk-battleship-relay binary) used for online play.
# The relay only forwards public messages between the two players' browsers.
NEXT_PUBLIC_RELAY_URL=ws://127.0.0.1:9000
